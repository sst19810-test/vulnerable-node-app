# ==========================================
# VULNERABILITY: Hardcoded secrets in .env
# CWE-798: Use of Hard-coded Credentials
# ==========================================

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=admin123
DB_NAME=appdb

# MongoDB
MONGO_URI=mongodb://admin:password123@localhost:27017/appdb

# JWT - Weak secret
JWT_SECRET=secret123
JWT_EXPIRY=never

# AWS Keys (hardcoded)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
S3_BUCKET=my-production-bucket

# Stripe (hardcoded payment secret)
STRIPE_SECRET_KEY=sk_live_51ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789

# Admin credentials hardcoded
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@company.com

# Session secret
SESSION_SECRET=mysecret

# Encryption key (weak, short)
ENCRYPTION_KEY=1234567890123456

# Internal API
INTERNAL_API_URL=http://internal-service.company.local
INTERNAL_API_TOKEN=internal-token-do-not-share

# Debug mode ON in production
DEBUG=true
NODE_ENV=production
PORT=3000
